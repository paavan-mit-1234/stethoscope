{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stethoscope",
  "version": "0.1.0",
  "identifier": "dev.stethoscope.app",
  "build": {
    "frontendDist": "../../../packages/ui/dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "pnpm --filter @stethoscope/ui dev",
    "beforeBuildCommand": "pnpm --filter @stethoscope/ui build"
  },
  "app": {
    "windows": [
      {
        "title": "Stethoscope",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
